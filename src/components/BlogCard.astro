---
const { title, description, date, url } = Astro.props;

const dateStr = new Date(date).toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<a
  href={url}
  class="target-lock crosshair-mask block border border-gray-200 rounded-lg p-5 hover:border-gray-400 transition-colors no-underline group"
>
  <div class="flex flex-col gap-2">
    <span
      class="font-mono font-medium text-base text-black group-hover:text-blue-700 transition-colors"
    >
      {title}
    </span>
    <span class="font-sans text-sm text-gray-500 leading-relaxed">
      {description}
    </span>
    <span class="font-mono text-xs text-gray-400 mt-1">
      {dateStr}
    </span>
  </div>
</a>
