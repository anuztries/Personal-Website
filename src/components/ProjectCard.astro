---
import FocusCroners from "./FocusCroners.astro";

const { title, description, thumbnail, url, language } = Astro.props;
---

<FocusCroners>
  <a
    href={url}
    class="crosshair-mask project-card block border border-gray-300 rounded-lg overflow-hidden hover:border-gray-500 transition-colors cursor-pointer no-underline"
  >
    {
      thumbnail ? (
        <img
          src={thumbnail}
          alt={title}
          class="w-full aspect-video object-cover"
        />
      ) : (
        <div class="w-full aspect-video bg-gray-200 flex items-center justify-center">
          <span class="font-mono text-xs text-gray-400">[ thumbnail ]</span>
        </div>
      )
    }
    <div class="p-3 flex flex-col gap-2">
      <div class="flex items-center justify-between">
        <span class="font-mono font-medium text-sm text-black">{title}</span>
        {
          language && (
            <span class="font-mono text-xs text-gray-400 border border-gray-200 px-2 py-0.5 rounded">
              {language}
            </span>
          )
        }
      </div>
      <span class="font-sans text-xs text-gray-500">{description}</span>
    </div>
  </a>
</FocusCroners>
