---
const { class: className = "", color: cornerColor = "#2563eb", size: cornerSize = 12 } = Astro.props;
---

<div class={"focus-corners-wrapper " + className} style={`--corner-color: ${cornerColor}; --corner-size: ${cornerSize}px;`}>
  <div class="focus-corners-inner">
    <slot />
  </div>
</div>

<style>
  .focus-corners-wrapper {
    position: relative;
    display: inline-block;
  }

  .focus-corners-inner {
    position: relative;
  }

  /* All four corners */
  .focus-corners-wrapper::before,
  .focus-corners-wrapper::after,
  .focus-corners-inner::before,
  .focus-corners-inner::after {
    content: "";
    position: absolute;
    width: var(--corner-size);
    height: var(--corner-size);
    opacity: 0;
    pointer-events: none;
    z-index: 100;
    /* Start slightly scaled down for zoom-in effect */
    transform: scale(0.5);
    transition: 
      opacity 0.2s cubic-bezier(0.4, 0, 0.2, 1),
      transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  /* Top-left corner */
  .focus-corners-wrapper::before {
    top: calc(var(--corner-size) * -0.3);
    left: calc(var(--corner-size) * -0.3);
    border-top: 2px solid var(--corner-color);
    border-left: 2px solid var(--corner-color);
    border-top-left-radius: 2px;
    box-shadow: 
      0 0 8px rgba(37, 99, 235, 0.3),
      inset 0 0 8px rgba(37, 99, 235, 0.1);
  }

  /* Top-right corner */
  .focus-corners-wrapper::after {
    top: calc(var(--corner-size) * -0.3);
    right: calc(var(--corner-size) * -0.3);
    border-top: 2px solid var(--corner-color);
    border-right: 2px solid var(--corner-color);
    border-top-right-radius: 2px;
    box-shadow: 
      0 0 8px rgba(37, 99, 235, 0.3),
      inset 0 0 8px rgba(37, 99, 235, 0.1);
  }

  /* Bottom-left corner */
  .focus-corners-inner::before {
    bottom: calc(var(--corner-size) * -0.3);
    left: calc(var(--corner-size) * -0.3);
    border-bottom: 2px solid var(--corner-color);
    border-left: 2px solid var(--corner-color);
    border-bottom-left-radius: 2px;
    box-shadow: 
      0 0 8px rgba(37, 99, 235, 0.3),
      inset 0 0 8px rgba(37, 99, 235, 0.1);
  }

  /* Bottom-right corner */
  .focus-corners-inner::after {
    bottom: calc(var(--corner-size) * -0.3);
    right: calc(var(--corner-size) * -0.3);
    border-bottom: 2px solid var(--corner-color);
    border-right: 2px solid var(--corner-color);
    border-bottom-right-radius: 2px;
    box-shadow: 
      0 0 8px rgba(37, 99, 235, 0.3),
      inset 0 0 8px rgba(37, 99, 235, 0.1);
  }

  /* Hover state - show all corners with staggered animation */
  .focus-corners-wrapper:hover::before {
    opacity: 1;
    transform: scale(1);
    transition-delay: 0s;
  }

  .focus-corners-wrapper:hover::after {
    opacity: 1;
    transform: scale(1);
    transition-delay: 0.05s;
  }

  .focus-corners-wrapper:hover .focus-corners-inner::before {
    opacity: 1;
    transform: scale(1);
    transition-delay: 0.1s;
  }

  .focus-corners-wrapper:hover .focus-corners-inner::after {
    opacity: 1;
    transform: scale(1);
    transition-delay: 0.15s;
  }
</style>
