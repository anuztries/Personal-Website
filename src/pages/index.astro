---
import ProjectCard from "../components/ProjectCard.astro";
import FocusCroners from "../components/FocusCroners.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const allPosts = await getCollection("blog");
const allProjects = await getCollection("projects");

const recentPosts = allPosts
  .filter(function (post) {
    return !post.data.draft;
  })
  .sort(function (a, b) {
    return b.data.date.getTime() - a.data.date.getTime();
  })
  .slice(0, 4)
  .map(function (post) {
    return {
      title: post.data.title,
      date: post.data.date,
      slug: post.id.replace(/\.md$/, "").replace(/\s+/g, "-").toLowerCase(),
    };
  });

const allActiveProjects = allProjects
  .filter(function (p) {
    return !p.data.draft;
  })
  .map(function (p) {
    return {
      ...p.data,
      slug: p.id.replace(/\.md$/, "").replace(/\s+/g, "-").toLowerCase(),
    };
  });

const pinnedProjects = allActiveProjects
  .filter(function (p) {
    return p.pinned;
  })
  .sort(function (a, b) {
    const aOrder = a.order ?? Infinity;
    const bOrder = b.order ?? Infinity;
    if (aOrder !== bOrder) return aOrder - bOrder;
    return b.date.getTime() - a.date.getTime();
  });

const unpinnedProjects = allActiveProjects
  .filter(function (p) {
    return !p.pinned;
  })
  .sort(function (a, b) {
    const aOrder = a.order ?? Infinity;
    const bOrder = b.order ?? Infinity;
    if (aOrder !== bOrder) return aOrder - bOrder;
    return b.date.getTime() - a.date.getTime();
  });

const homepageProjects =
  pinnedProjects.length >= 3
    ? pinnedProjects.slice(0, 3)
    : [...pinnedProjects, ...unpinnedProjects].slice(0, 3);
---

<BaseLayout>
  <div class="min-h-screen flex flex-col gap-16 py-12 px-8">
    <!-- Hero Section: Schematic Sheet -->
    <section class="schematic-frame">
      <div class="schematic-inner flex flex-col gap-5">
        <!-- Top: Title -->
        <div class="flex justify-end">
          <h1 class="font-mono font-bold text-4xl tracking-tight text-black">
            &lt; ANUJ KHATRI/&gt;
          </h1>
        </div>

        <!-- Middle: Photo + Bio/Socials -->
        <div class="flex flex-row items-start gap-8">
          <!-- Left: Photo -->
          <div class="flex flex-col gap-2">
            <span class="font-mono text-xs text-black">[This is me]</span>
            <FocusCroners>
              <img
                src="/profilepic.jpg"
                alt="Anuj Khatri"
                class="crosshair-mask w-48 h-60 object-cover object-top rounded-md border border-black"
              />
            </FocusCroners>
          </div>

          <!-- Right: Bio + Socials -->
          <div class="flex flex-col gap-5 pt-1">
            <div class="flex flex-col gap-1">
              <p class="font-mono text-base text-black">&gt; Hello World!</p>
              <p class="font-mono text-base text-black">
                &gt; I am a wanna-be polymath
              </p>
              <p class="font-mono text-base text-black">
                &gt; I build things with code, circuits, and whatever I can
                find.
              </p>
            </div>

            <div class="flex flex-col gap-2">
              <span class="font-mono text-xs text-black">user /socials</span>
              <div class="flex flex-row gap-3">
                <FocusCroners>
                  <a
                    href="https://linkedin.com/in/yourprofile"
                    target="_blank"
                    class="crosshair-mask link-button text-black border-black hover:border-black"
                  >
                    [LinkedIn]
                  </a>
                </FocusCroners>
                <FocusCroners>
                  <a
                    href="https://github.com/yourusername"
                    target="_blank"
                    class="crosshair-mask link-button text-black border-black hover:border-black"
                  >
                    [GitHub]
                  </a>
                </FocusCroners>
                <FocusCroners>
                  <a
                    href="https://instagram.com/yourprofile"
                    target="_blank"
                    class="crosshair-mask link-button text-black border-black hover:border-black"
                  >
                    [Instagram]
                  </a>
                </FocusCroners>
                <FocusCroners>
                  <a
                    href="/resume.pdf"
                    target="_blank"
                    class="crosshair-mask link-button text-black border-black hover:border-black"
                  >
                    [Resume]
                  </a>
                </FocusCroners>
              </div>
            </div>
          </div>
        </div>

        <!-- Bottom: Title Block (right-aligned) -->
        <div class="flex justify-end">
          <div class="title-block w-72">
            <div class="title-block-row">
              <span class="title-block-label w-20">TITLE</span>
              <span class="title-block-value">Anuj Khatri — Home</span>
            </div>
            <div class="title-block-row">
              <span class="title-block-label w-20">PAGE</span>
              <span class="title-block-value">1 of 1 (it's just me)</span>
            </div>
            <div class="title-block-row">
              <span class="title-block-label w-20">AUTHOR</span>
              <span class="title-block-value">Anuj Khatri</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Divider -->
    <hr class="border-gray-300" />

    <!-- Recent Projects Section -->
    <section class="flex flex-col gap-6">
      <h2 class="font-mono font-medium tracking-tight">/Recent Projects</h2>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {
          homepageProjects.length === 0 && (
            <p class="font-mono text-sm text-gray-400 col-span-3">
              [ no projects yet ]
            </p>
          )
        }
        {
          homepageProjects.map(function (project) {
            const dateStr = new Date(project.date).toLocaleDateString("en-US", {
              year: "numeric",
              month: "long",
              day: "numeric",
            });
            return (
              <a
                href={"/projects/" + project.slug}
                class="crosshair-mask focus-corners flex flex-col gap-0 border border-gray-200 rounded-lg overflow-hidden hover:border-gray-400 transition-colors no-underline group"
              >
                <div class="w-full aspect-video bg-gray-100 overflow-hidden flex items-center justify-center">
                  {project.thumbnail ? (
                    <img
                      src={project.thumbnail}
                      alt={project.title}
                      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                    />
                  ) : (
                    <span class="font-mono text-xs text-gray-400">
                      [ no thumbnail ]
                    </span>
                  )}
                </div>
                <div class="p-4 flex flex-col gap-1">
                  <span class="font-mono font-medium text-sm text-black group-hover:text-blue-700 transition-colors">
                    {project.title}
                  </span>
                  <span class="font-mono text-xs text-gray-400">{dateStr}</span>
                  <span class="hidden sm:block font-sans text-sm text-gray-500 leading-relaxed mt-1">
                    {project.description}
                  </span>
                </div>
              </a>
            );
          })
        }
      </div>

      <a
        href="/projects"
        class="crosshair-mask font-mono text-sm w-fit border-b border-gray-400 hover:border-black transition-colors"
      >
        [View all projects →]
      </a>
    </section>

    <!-- Divider -->
    <hr class="border-gray-300" />

    <!-- Recent Blog Posts Section -->
    <section class="flex flex-col gap-6">
      <h2 class="font-mono font-medium tracking-tight">/Recent Writings</h2>

      <div class="flex flex-col gap-3">
        {
          recentPosts.length === 0 && (
            <p class="font-mono text-sm text-gray-400">[ no posts yet ]</p>
          )
        }
        {
          recentPosts.map(function (post) {
            const dateStr = new Date(post.date).toLocaleDateString("en-US", {
              year: "numeric",
              month: "short",
              day: "numeric",
            });
            return (
              <a
                href={"/writing/" + post.slug}
                class="flex flex-row items-baseline justify-between border-b border-gray-200 py-4 no-underline group"
              >
                <span class="font-mono text-base text-black group-hover:text-blue-600 transition-colors">
                  [{post.title}]
                </span>
                <span class="font-mono text-sm text-gray-400 shrink-0 ml-4">
                  {dateStr}
                </span>
              </a>
            );
          })
        }
      </div>

      <a
        href="/writing"
        class="crosshair-mask font-mono text-sm w-fit border-b border-gray-400 hover:border-black transition-colors"
      >
        [View all posts →]
      </a>
    </section>
  </div>
</BaseLayout>
